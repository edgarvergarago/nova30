<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, push, onValue, remove } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const app = initializeApp({
  apiKey:"AIzaSyDZIRNjfOXwAPdf_FODCS2nJSEfzFrcjvE",
  authDomain:"nova30-97f1b.firebaseapp.com",
  databaseURL:"https://nova30-97f1b-default-rtdb.firebaseio.com",
  projectId:"nova30-97f1b",
  storageBucket:"nova30-97f1b.firebasestorage.app",
  messagingSenderId:"775146781721",
  appId:"1:775146781721:web:3e6390b107a1829a3cfe88"
},'boost-pocket');
const db = getDatabase(app);
const DB = p => ref(db,'boost_pocket/'+p);
const PASS = "boost2026admin";
let user = null;

function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}
window.showScreen=id=>{document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');};
window.openModal=id=>document.getElementById(id).classList.add('open');
window.closeModal=id=>document.getElementById(id).classList.remove('open');
window.switchTab=(n,el)=>{document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));document.getElementById('tab-'+n).classList.add('active');el.classList.add('active');};
window.switchAdminTab=n=>{document.querySelectorAll('.adm-section').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.adm-tab').forEach(t=>t.classList.remove('active'));document.getElementById('admin-'+n).classList.add('active');event.currentTarget.classList.add('active');};
window.handleLogin=()=>{const p=document.getElementById('login-phone').value.trim();if(p.length<7){document.getElementById('login-error').style.display='block';return;}document.getElementById('login-error').style.display='none';user={phone:p};localStorage.setItem('bp_user',JSON.stringify(user));document.getElementById('nav-user').textContent=p;showScreen('screen-app');loadAll();};
window.handleGuest=()=>{user={phone:'invitado',guest:true};document.getElementById('nav-user').textContent='Invitado';showScreen('screen-app');loadAll();};
window.handleLogout=()=>{user=null;localStorage.removeItem('bp_user');showScreen('screen-login');};
window.handleAdminLogin=()=>{if(document.getElementById('admin-pass').value===PASS){document.getElementById('admin-error').style.display='none';showScreen('screen-admin');loadAdminData();}else{document.getElementById('admin-error').style.display='block';}};

function loadAll(){loadAgenda();loadMembers();}

function loadAgenda(){onValue(DB('agenda'),snap=>{renderSchedule(snap.val()||{});});}
function renderSchedule(data){
  const list=document.getElementById('schedule-list');
  const entries=Object.entries(data).sort((a,b)=>(a[1].order||999)-(b[1].order||999));
  if(!entries.length){list.innerHTML='<p style="color:var(--ink-mid);font-size:13px;padding:32px 0;text-align:center">La agenda se publicará pronto</p>';return;}
  list.innerHTML=entries.map(([id,e])=>{
    const tc='t-'+(e.type||'ponencia');
    return`<div class="sch-item ${tc}"><div class="sch-time">${e.time||''}</div><div class="sch-card"><div class="sch-title">${e.title}</div>${e.speaker?`<div class="sch-speaker">${e.speaker}</div>`:''}</div></div>`;
  }).join('');
}

function loadMembers(){onValue(DB('members'),snap=>{
  const data=snap.val()||{};
  const entries=Object.entries(data);
  document.getElementById('mem-count').innerHTML=`<strong>${entries.length}</strong> miembro${entries.length!==1?'s':''}`;
  const grid=document.getElementById('mem-grid');
  if(!entries.length){grid.innerHTML='<div class="empty-state"><div class="icon">🙌</div><p>Sé el primero en agregar tu perfil</p></div>';return;}
  grid.innerHTML=entries.map(([id,m])=>{
    const ini=(m.name||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
    return`<div class="mem-card"><div class="mem-avatar">${ini}</div><div class="mem-name">${m.name||''}</div><div class="mem-skill">${m.skill||''}</div><div class="mem-country">${m.country||''}</div><div class="mem-links">${m.ig?`<a href="https://instagram.com/${m.ig.replace('@','')}" target="_blank" class="mem-link">📸 ${m.ig}</a>`:''} ${m.email?`<a href="mailto:${m.email}" class="mem-link">✉️ email</a>`:''}</div>${m.challenge?`<div class="mem-challenge">"${m.challenge}"</div>`:''}</div>`;
  }).join('');
});}

window.saveMember=async()=>{
  const name=document.getElementById('m-name').value.trim();
  if(!name){toast('El nombre es obligatorio');return;}
  await push(DB('members'),{name,skill:document.getElementById('m-skill').value.trim(),country:document.getElementById('m-country').value.trim(),phone:document.getElementById('m-phone').value.trim()||user?.phone,ig:document.getElementById('m-ig').value.trim(),email:document.getElementById('m-email').value.trim(),challenge:document.getElementById('m-challenge').value.trim(),at:new Date().toISOString()});
  closeModal('modal-member');toast('✅ Perfil agregado');
};

function loadAdminData(){
  onValue(DB('agenda'),snap=>{
    const data=snap.val()||{};
    const tbody=document.getElementById('adm-agenda-body');
    const entries=Object.entries(data).sort((a,b)=>(a[1].order||999)-(b[1].order||999));
    tbody.innerHTML=entries.map(([id,e])=>`<tr><td style="color:var(--ink-mid)">${e.order||''}</td><td style="font-weight:600;color:var(--fire)">${e.time}</td><td>${e.title}</td><td style="color:var(--ink-mid)">${e.type}</td><td><button class="btn-danger" onclick="deleteEntry('agenda/${id}')">✕</button></td></tr>`).join('')||'<tr><td colspan="5" style="color:var(--ink-mid)">Sin sesiones</td></tr>';
  },{onlyOnce:true});
  onValue(DB('members'),snap=>{
    const data=snap.val()||{};
    const tbody=document.getElementById('adm-members-body');
    tbody.innerHTML=Object.entries(data).map(([id,m])=>`<tr><td style="font-weight:600">${m.name}</td><td>${m.country||''}</td><td style="color:var(--fire)">${m.skill||''}</td><td>${m.phone||''}</td><td><button class="btn-danger" onclick="deleteEntry('members/${id}')">✕</button></td></tr>`).join('')||'<tr><td colspan="5" style="color:var(--ink-mid)">Sin miembros</td></tr>';
  },{onlyOnce:true});
}

window.saveAgendaItem=async()=>{
  const title=document.getElementById('ag-title').value.trim();
  const time=document.getElementById('ag-time').value.trim();
  const order=parseInt(document.getElementById('ag-order').value)||99;
  if(!title||!time){toast('Hora y título son obligatorios');return;}
  await push(DB('agenda'),{title,time,order,type:document.getElementById('ag-type').value,speaker:document.getElementById('ag-speaker').value.trim(),at:new Date().toISOString()});
  ['ag-title','ag-time','ag-speaker','ag-order'].forEach(id=>document.getElementById(id).value='');
  toast('✅ Sesión agregada');loadAdminData();
};

window.deleteEntry=async path=>{
  if(!confirm('¿Eliminar?'))return;
  await remove(ref(db,'boost_pocket/'+path));
  toast('Eliminado');loadAdminData();
};

const saved=localStorage.getItem('bp_user');
if(saved){user=JSON.parse(saved);document.getElementById('nav-user').textContent=user.phone;showScreen('screen-app');loadAll();}
