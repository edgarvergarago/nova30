<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Hotmart Boost · Dynamis Pocket</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --fire: #FC3F03;
      --fire-soft: rgba(252,63,3,0.1);
      --fire-border: rgba(252,63,3,0.2);
      --bg: #f5f3f0;
      --bg2: #ffffff;
      --bg3: #eeebe7;
      --ink: #111111;
      --ink-mid: rgba(17,17,17,0.5);
      --ink-faint: rgba(17,17,17,0.12);
      --r: 12px;
      --font-head: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--ink); font-family: var(--font-body); min-height: 100vh; -webkit-font-smoothing: antialiased; }
    .screen { display: none; min-height: 100vh; flex-direction: column; }
    .screen.active { display: flex; }

    /* LOGIN */
    #screen-login { align-items: center; justify-content: center; background: var(--ink); position: relative; overflow: hidden; }
    #screen-login::before { content: 'BOOST'; position: absolute; font-family: var(--font-head); font-weight: 800; font-size: clamp(100px, 22vw, 240px); color: rgba(255,255,255,0.03); letter-spacing: -8px; top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; white-space: nowrap; }
    .login-wrap { position: relative; z-index: 1; width: 100%; max-width: 380px; padding: 20px; }
    .login-logo-area { margin-bottom: 32px; display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }
    .login-logo-area svg { width: 140px; }
    .login-subtitle { font-family: var(--font-head); font-size: 10px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--fire); border-left: 2px solid var(--fire); padding-left: 8px; }
    .login-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--r); padding: 32px; }
    .login-card h2 { font-family: var(--font-head); font-size: 26px; font-weight: 800; color: #fff; margin-bottom: 6px; letter-spacing: -0.5px; }
    .login-card p { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 24px; }
    .field { margin-bottom: 14px; }
    .field label { display: block; font-size: 10px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 7px; }
    .field input { width: 100%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; padding: 13px 16px; color: #fff; font-family: var(--font-body); font-size: 14px; outline: none; transition: border-color 0.2s; }
    .field input:focus { border-color: var(--fire); }
    .field input::placeholder { color: rgba(255,255,255,0.2); }
    .btn-enter { width: 100%; background: var(--fire); color: #fff; border: none; border-radius: 8px; padding: 14px; font-family: var(--font-head); font-size: 16px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
    .btn-enter:hover { opacity: 0.88; transform: translateY(-1px); }
    .login-error { font-size: 12px; color: var(--fire); margin-bottom: 12px; display: none; }
    .login-guest { text-align: center; margin-top: 14px; font-size: 12px; color: rgba(255,255,255,0.25); cursor: pointer; transition: color 0.2s; }
    .login-guest:hover { color: rgba(255,255,255,0.5); }

    /* NAV */
    .nav { background: var(--ink); position: sticky; top: 0; z-index: 100; display: flex; align-items: center; height: 52px; padding: 0 20px; gap: 0; }
    .nav-logo { display: flex; align-items: center; padding-right: 14px; border-right: 1px solid rgba(255,255,255,0.08); margin-right: 10px; flex-shrink: 0; cursor: pointer; }
    .nav-logo svg { width: 76px; }
    .nav-pill { font-family: var(--font-head); font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--fire); background: rgba(252,63,3,0.12); border: 1px solid rgba(252,63,3,0.2); border-radius: 100px; padding: 3px 10px; margin-right: 14px; flex-shrink: 0; }
    .nav-tabs { display: flex; gap: 2px; overflow-x: auto; scrollbar-width: none; flex: 1; }
    .nav-tabs::-webkit-scrollbar { display: none; }
    .nav-tab { padding: 7px 14px; font-family: var(--font-body); font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.3); border: none; background: none; border-radius: 6px; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .nav-tab:hover { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.05); }
    .nav-tab.active { color: #fff; background: rgba(255,255,255,0.08); }
    .nav-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
    .nav-user { font-size: 11px; color: rgba(255,255,255,0.2); }
    .btn-out { font-size: 11px; color: rgba(255,255,255,0.25); border: 1px solid rgba(255,255,255,0.1); background: none; border-radius: 6px; padding: 5px 10px; cursor: pointer; font-family: var(--font-body); transition: all 0.15s; }
    .btn-out:hover { color: rgba(255,255,255,0.6); }

    /* CONTENT */
    .content { flex: 1; max-width: 680px; margin: 0 auto; width: 100%; padding: 40px 20px 60px; animation: up 0.3s ease; }
    @keyframes up { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* PAGE HEADER */
    .page-header { margin-bottom: 28px; }
    .overline { font-size: 10px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--fire); margin-bottom: 8px; }
    .page-header h1 { font-family: var(--font-head); font-size: 38px; font-weight: 800; letter-spacing: -1.5px; line-height: 1; margin-bottom: 8px; }
    .page-header p { font-size: 14px; color: var(--ink-mid); }

    /* SCHEDULE */
    .schedule { position: relative; }
    .schedule::before { content:''; position: absolute; left: 47px; top:0; bottom:0; width:1px; background: var(--ink-faint); }
    .sch-item { display: grid; grid-template-columns: 48px 1fr; gap: 0; margin-bottom: 4px; position: relative; }
    .sch-time { font-family: var(--font-head); font-size: 12px; font-weight: 600; color: var(--ink-mid); padding-top: 15px; text-align: right; padding-right: 14px; }
    .sch-item::after { content:''; position: absolute; left: 44px; top: 19px; width: 7px; height: 7px; border-radius: 50%; background: var(--ink-faint); border: 2px solid var(--bg); z-index: 1; }
    .sch-item.t-break::after, .sch-item.t-cierre::after { background: var(--ink); }
    .sch-item.t-hotseat::after, .sch-item.t-highlight::after { background: var(--fire); }
    .sch-card { background: var(--bg2); border: 1px solid var(--ink-faint); border-radius: var(--r); padding: 14px 18px; margin-left: 14px; transition: box-shadow 0.15s; }
    .sch-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .sch-item.t-break .sch-card, .sch-item.t-cierre .sch-card { background: var(--ink); border-color: var(--ink); }
    .sch-item.t-break .sch-title, .sch-item.t-cierre .sch-title { color: #fff; text-align: center; }
    .sch-item.t-hotseat .sch-card, .sch-item.t-highlight .sch-card { background: var(--fire); border-color: var(--fire); }
    .sch-item.t-hotseat .sch-title, .sch-item.t-highlight .sch-title { color: #fff; }
    .sch-item.t-hotseat .sch-speaker, .sch-item.t-highlight .sch-speaker { color: rgba(255,255,255,0.65); }
    .sch-item.t-hotseat .sch-time, .sch-item.t-highlight .sch-time { color: var(--fire); }
    .sch-title { font-family: var(--font-head); font-size: 14px; font-weight: 700; color: var(--ink); line-height: 1.35; letter-spacing: -0.2px; }
    .sch-speaker { font-size: 12px; color: var(--ink-mid); margin-top: 3px; }

    /* MEMBERS */
    .mem-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
    .mem-count { font-family: var(--font-head); font-size: 13px; font-weight: 700; color: var(--ink-mid); }
    .mem-count strong { color: var(--fire); font-size: 20px; }
    .btn-add { background: var(--ink); color: #fff; border: none; border-radius: 8px; padding: 10px 18px; font-family: var(--font-head); font-size: 13px; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: opacity 0.15s; }
    .btn-add:hover { opacity: 0.7; }
    .mem-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(195px, 1fr)); gap: 10px; }
    .mem-card { background: var(--bg2); border: 1px solid var(--ink-faint); border-radius: var(--r); padding: 18px; transition: all 0.2s; }
    .mem-card:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
    .mem-avatar { width: 38px; height: 38px; border-radius: 9px; background: var(--fire-soft); border: 1px solid var(--fire-border); display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-size: 13px; font-weight: 800; color: var(--fire); margin-bottom: 11px; }
    .mem-name { font-family: var(--font-head); font-size: 14px; font-weight: 700; margin-bottom: 2px; }
    .mem-skill { font-size: 11px; font-weight: 500; color: var(--fire); margin-bottom: 4px; }
    .mem-country { font-size: 11px; color: var(--ink-mid); margin-bottom: 8px; }
    .mem-links { display: flex; gap: 8px; flex-wrap: wrap; }
    .mem-link { font-size: 11px; color: var(--ink-mid); text-decoration: none; transition: color 0.15s; }
    .mem-link:hover { color: var(--fire); }
    .mem-challenge { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--ink-faint); font-size: 11px; color: var(--ink-mid); font-style: italic; line-height: 1.5; }
    .empty-state { grid-column: 1/-1; text-align: center; padding: 56px 20px; color: var(--ink-mid); }
    .empty-state .icon { font-size: 32px; margin-bottom: 10px; }

    /* EVAL */
    .eval-banner { background: var(--ink); border-radius: var(--r); padding: 24px 28px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .eval-banner h3 { font-family: var(--font-head); font-size: 22px; font-weight: 800; color: #fff; letter-spacing: -0.5px; margin-bottom: 4px; }
    .eval-banner p { font-size: 13px; color: rgba(255,255,255,0.4); }
    .eval-icon { font-size: 40px; }
    .tf-wrap { background: var(--bg2); border: 1px solid var(--ink-faint); border-radius: var(--r); overflow: hidden; }
    .tf-wrap iframe { display: block; width: 100%; height: 580px; border: none; }

    /* MODAL */
    .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.65); backdrop-filter: blur(6px); z-index: 1000; display: none; align-items: center; justify-content: center; padding: 20px; }
    .overlay.open { display: flex; }
    .modal { background: var(--bg2); border: 1px solid var(--ink-faint); border-radius: 16px; padding: 28px; width: 100%; max-width: 440px; max-height: 88vh; overflow-y: auto; }
    .modal-title { font-family: var(--font-head); font-size: 22px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 20px; }
    .modal-title span { color: var(--fire); }
    .fg { margin-bottom: 13px; }
    .fl { display: block; font-size: 10px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink-mid); margin-bottom: 6px; }
    .fi { width: 100%; background: var(--bg); border: 1px solid var(--ink-faint); border-radius: 8px; padding: 11px 14px; color: var(--ink); font-family: var(--font-body); font-size: 13px; outline: none; transition: border-color 0.2s; }
    .fi:focus { border-color: var(--fire); }
    .fta { width: 100%; background: var(--bg); border: 1px solid var(--ink-faint); border-radius: 8px; padding: 11px 14px; color: var(--ink); font-family: var(--font-body); font-size: 13px; outline: none; resize: none; min-height: 68px; transition: border-color 0.2s; }
    .fta:focus { border-color: var(--fire); }
    .fr { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media (max-width: 440px) { .fr { grid-template-columns: 1fr; } }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 18px; }
    .btn-cancel { background: none; border: 1px solid var(--ink-faint); color: var(--ink-mid); border-radius: 8px; padding: 10px 16px; font-family: var(--font-body); font-size: 13px; cursor: pointer; }
    .btn-save { background: var(--ink); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-family: var(--font-head); font-size: 14px; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: opacity 0.15s; }
    .btn-save:hover { opacity: 0.7; }

    /* ADMIN */
    #screen-admin-login { align-items: center; justify-content: center; background: var(--ink); }
    #screen-admin { flex-direction: column; background: var(--bg); }
    .adm-nav { background: var(--ink); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 24px; display: flex; align-items: center; gap: 12px; }
    .adm-nav-title { font-family: var(--font-head); font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--fire); }
    .adm-nav-right { margin-left: auto; display: flex; gap: 8px; }
    .adm-body { padding: 28px 24px; max-width: 780px; margin: 0 auto; width: 100%; }
    .adm-tabs { display: flex; gap: 2px; margin-bottom: 22px; border-bottom: 1px solid var(--ink-faint); }
    .adm-tab { padding: 9px 16px; font-family: var(--font-body); font-size: 13px; font-weight: 500; color: var(--ink-mid); cursor: pointer; border: none; background: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
    .adm-tab.active { color: var(--fire); border-bottom-color: var(--fire); }
    .adm-section { display: none; }
    .adm-section.active { display: block; }
    .card { background: var(--bg2); border: 1px solid var(--ink-faint); border-radius: var(--r); padding: 20px; margin-bottom: 10px; }
    .btn-danger { background: none; color: #e53e3e; border: 1px solid rgba(229,62,62,0.25); border-radius: 5px; padding: 5px 10px; font-size: 11px; cursor: pointer; font-family: var(--font-body); }
    .adm-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .adm-table th { text-align: left; padding: 8px 12px; font-size: 10px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--ink-mid); border-bottom: 1px solid var(--ink-faint); }
    .adm-table td { padding: 11px 12px; border-bottom: 1px solid rgba(0,0,0,0.04); vertical-align: middle; }

    /* TOAST */
    #toast { position: fixed; bottom: 24px; right: 24px; background: var(--ink); color: #fff; border-left: 3px solid var(--fire); padding: 12px 18px; border-radius: 8px; font-size: 13px; z-index: 9999; transform: translateY(60px); opacity: 0; transition: all 0.25s; }
    #toast.show { transform: translateY(0); opacity: 1; }

    @media (max-width: 600px) {
      .content { padding: 24px 14px 48px; }
      .page-header h1 { font-size: 28px; }
      .eval-banner { padding: 18px 20px; }
    }
  </style>
</head>
